BOT_TOKEN=
# The Discord user ID of the bot author/maintainer
AUTHOR_ID=
# The environment the bot is running in (development or production)
NODE_ENV=production
# Optional telemetry forwarding target
TELEMETRY_URL=
TELEMETRY_TOKEN=
# Optional Prometheus port override
METRICS_PORT=9464
# Optional PostgreSQL connection string. Backs match telemetry persistence and
# per-server language config (/set-language). Without it, /set-language is
# unavailable and the bot falls back to the Discord server locale.
DATABASE_URL=
# Optional overrides for schema/table names (must be valid identifiers)
DATABASE_SCHEMA=public
TELEMETRY_EVENTS_TABLE=telemetry_events
GUILD_CONFIG_TABLE=guild_config
